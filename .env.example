# ============================================================
# Gamenight — Environment Configuration
# ============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production, set these as real environment variables.
# Never commit your .env file to version control.
# ============================================================

# --- Flask Core ---
FLASK_APP=app
# Entry point for Flask CLI (flask run, flask db, etc.)

FLASK_ENV=development
# development = auto-reload, debug toolbar, detailed errors
# production = optimized, no debug output

FLASK_DEBUG=1
# 1 = development mode (auto-reload). Set to 0 in production.

SECRET_KEY=change-me-to-a-long-random-string
# REQUIRED IN PRODUCTION. Generate a secure key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Used for: session encryption, CSRF token signing, password reset tokens.

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/gamenight
# Format: postgresql://username:password@host:port/database_name
# For Docker Compose: postgresql://postgres:postgres@db:5432/gamenight

TEST_DATABASE_URL=postgresql://user:password@localhost:5432/gamenight_test
# Separate database used by pytest. Create it with:
#   createdb gamenight_test
# Set automatically in GitHub Actions CI.

# --- Session ---
SESSION_TYPE=filesystem
# filesystem = store sessions in /tmp (default for local dev)
# null = in-memory only (used automatically in tests)
# redis = recommended for production (requires additional setup)

# --- Timezone ---
APP_TIMEZONE=America/Chicago
# Timezone for game night scheduling. Uses pytz timezone names.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones

# --- Email (Flask-Mail) ---
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
# If using Gmail, generate an App Password (not your account password):
# https://support.google.com/accounts/answer/185833
MAIL_DEFAULT_SENDER=your-email@example.com
# "From" address shown on password reset and reminder emails.
